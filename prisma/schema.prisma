generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  passwordHash  String         @map("password_hash")
  displayName   String         @map("display_name")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  uploadedFiles ResourceFile[] @relation("UploadedFiles")
  operationLogs OperationLog[]

  @@map("users")
}

model WorkOrder {
  id            String         @id @default(uuid())
  code          String         @unique
  customerName  String?        @map("customer_name")
  productName   String         @map("product_name")
  stage         String
  progress      Int            @default(0)
  priority      String         @default("normal")
  status        String         @default("processing")
  plannedAt     DateTime?      @map("planned_at")
  remark        String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  resourceFiles ResourceFile[]

  @@index([priority])
  @@index([status])
  @@index([deletedAt])
  @@map("work_orders")
}

model ResourceCategory {
  id            String         @id @default(uuid())
  name          String
  code          String         @unique
  sortOrder     Int            @default(0) @map("sort_order")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  resourceFiles ResourceFile[]

  @@map("resource_categories")
}

model ResourceFile {
  id           String    @id @default(uuid())
  workOrderId  String    @map("work_order_id")
  categoryId   String    @map("category_id")
  originalName String    @map("original_name")
  displayName  String?   @map("display_name")
  mimeType     String    @map("mime_type")
  fileType     String    @map("file_type")
  fileSize     Int       @map("file_size")
  objectKey    String    @map("object_key")
  version      String    @default("V1.0")
  remark       String?
  status       String    @default("uploaded")
  uploadedById String?   @map("uploaded_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  category     ResourceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uploadedBy   User?     @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([workOrderId, categoryId, status, deletedAt])
  @@index([objectKey])
  @@map("resource_files")
}

model OperationLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("operation_logs")
}

model ConnectorParameter {
  id                String    @id @default(cuid())
  rowNo             Int?      @map("row_no")
  model             String?
  outerPeelMm       String?   @map("outer_peel_mm")
  innerPeelMm       String?   @map("inner_peel_mm")
  insertionLengthMm String?   @map("insertion_length_mm")
  remark            String?
  isHighlighted     Boolean   @default(false) @map("is_highlighted")
  createdBy         String?   @map("created_by")
  updatedBy         String?   @map("updated_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  @@index([rowNo])
  @@index([model])
  @@index([isHighlighted])
  @@index([deletedAt])
  @@map("connector_parameters")
}

model ConnectorParameterFile {
  id           String    @id @default(cuid())
  originalName String    @map("original_name")
  displayName  String?   @map("display_name")
  mimeType     String    @map("mime_type")
  fileType     String    @map("file_type")
  fileSize     Int       @map("file_size")
  objectKey    String    @map("object_key")
  uploadedBy   String?   @map("uploaded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@index([createdAt])
  @@map("connector_parameter_files")
}
