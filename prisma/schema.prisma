generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String                      @id @default(uuid())
  username                    String                      @unique
  passwordHash                String                      @map("password_hash")
  displayName                 String                      @map("display_name")
  isActive                    Boolean                     @default(true) @map("is_active")
  createdAt                   DateTime                    @default(now()) @map("created_at")
  updatedAt                   DateTime                    @updatedAt @map("updated_at")
  uploadedFiles               ResourceFile[]              @relation("UploadedFiles")
  drawingLibraryFiles         DrawingLibraryFile[]        @relation("UploadedDrawingLibraryFiles")
  operationLogs               OperationLog[]
  reportedIssues              Issue[]                     @relation("IssueReporter")
  assignedIssues              Issue[]                     @relation("IssueAssignee")
  issueActivities             IssueActivity[]             @relation("IssueActivityActor")
  issueAttachments            IssueAttachment[]           @relation("IssueAttachmentUploader")
  requestedChanges            ChangeRequest[]             @relation("ChangeRequester")
  ownedChanges                ChangeRequest[]             @relation("ChangeOwner")
  changeActivities            ChangeActivity[]            @relation("ChangeActivityActor")
  changeAttachments           ChangeAttachment[]          @relation("ChangeAttachmentUploader")
  completedMaterialTasks      WarehouseMaterialTask[]     @relation("WarehouseTaskCompletedBy")
  updatedMaterialTasks        WarehouseMaterialTask[]     @relation("WarehouseTaskUpdatedBy")
  warehouseActivities         WarehouseMaterialActivity[] @relation("WarehouseActivityActor")
  createdProcessTemplates     ProcessTemplate[]           @relation("ProcessTemplateCreatedBy")
  createdProcessTimeStandards ProcessTimeStandard[]       @relation("ProcessTimeStandardCreatedBy")
  confirmedProcessRoutes      WorkOrderProcessRoute[]     @relation("ProcessRouteConfirmedBy")
  completedProcessSteps       WorkOrderProcessStep[]      @relation("ProcessStepCompletedBy")
  recordedProcessExecutions   ProcessExecution[]          @relation("ProcessExecutionRecordedBy")
  processRouteActivities      ProcessRouteActivity[]      @relation("ProcessRouteActivityActor")

  @@map("users")
}

model WorkOrder {
  id                      String                 @id @default(uuid())
  code                    String                 @unique
  customerName            String?                @map("customer_name")
  productName             String                 @map("product_name")
  stage                   String
  progress                Int                    @default(0)
  priority                String                 @default("normal")
  status                  String                 @default("processing")
  plannedAt               DateTime?              @map("planned_at")
  remark                  String?
  sourceOrderNo           String?                @map("source_order_no")
  salesperson             String?
  orderDate               DateTime?              @map("order_date")
  customerLevel           String?                @map("customer_level")
  specification           String?
  processName             String?                @map("process_name")
  uncompletedQty          String?                @map("uncompleted_qty")
  productionTargetQty     Int?                   @map("production_target_qty")
  unitWorkHours           String?                @map("unit_work_hours")
  totalWorkHours          String?                @map("total_work_hours")
  drawingStatus           String?                @map("drawing_status")
  deliveryDay             String?                @map("delivery_day")
  materialStatus          String?                @map("material_status")
  drawingIssuedAt         DateTime?              @map("drawing_issued_at")
  drawingIssueNote        String?                @map("drawing_issue_note")
  importBatchId           String?                @map("import_batch_id")
  sourceSheetName         String?                @map("source_sheet_name")
  sourceRowNo             Int?                   @map("source_row_no")
  planType                String?                @map("plan_type")
  weekStartDate           DateTime?              @map("week_start_date")
  weekEndDate             DateTime?              @map("week_end_date")
  planActive              Boolean                @default(true) @map("plan_active")
  planClearedAt           DateTime?              @map("plan_cleared_at")
  planClearedBy           String?                @map("plan_cleared_by")
  libraryKey              String?                @map("library_key")
  drawingLibraryItemId    String?                @map("drawing_library_item_id")
  productionOwner         String?                @map("production_owner")
  workstation             String?
  completedQty            String?                @map("completed_qty")
  frontendTransferredQty  Int?                   @map("frontend_transferred_qty")
  executionVersion        Int                    @default(0) @map("execution_version")
  startedAt               DateTime?              @map("started_at")
  completedAt             DateTime?              @map("completed_at")
  lastProgressAt          DateTime?              @map("last_progress_at")
  latestProgressRemark    String?                @map("latest_progress_remark")
  createdAt               DateTime               @default(now()) @map("created_at")
  updatedAt               DateTime               @updatedAt @map("updated_at")
  deletedAt               DateTime?              @map("deleted_at")
  resourceFiles           ResourceFile[]
  drawingLibraryItem      DrawingLibraryItem?    @relation("DrawingLibraryWorkOrders", fields: [drawingLibraryItemId], references: [id], onDelete: SetNull)
  lastDrawingLibraryItems DrawingLibraryItem[]   @relation("LastDrawingLibraryWorkOrder")
  progressLogs            WorkOrderProgressLog[]
  issues                  Issue[]
  changeRequests          ChangeRequest[]
  materialTask            WarehouseMaterialTask?
  processRoute            WorkOrderProcessRoute?

  @@index([code])
  @@index([productName])
  @@index([customerName])
  @@index([stage])
  @@index([plannedAt])
  @@index([createdAt])
  @@index([priority])
  @@index([status])
  @@index([deletedAt])
  @@index([sourceOrderNo])
  @@index([salesperson])
  @@index([specification])
  @@index([importBatchId])
  @@index([sourceRowNo])
  @@index([planType])
  @@index([weekStartDate])
  @@index([planActive])
  @@index([libraryKey])
  @@index([drawingLibraryItemId])
  @@index([productionOwner])
  @@index([workstation])
  @@index([lastProgressAt])
  @@map("work_orders")
}

model ProcessDefinition {
  id            String                 @id @default(uuid())
  code          String                 @unique
  name          String
  stageGroup    String                 @map("stage_group")
  isActive      Boolean                @default(true) @map("is_active")
  sortOrder     Int                    @default(0) @map("sort_order")
  createdAt     DateTime               @default(now()) @map("created_at")
  updatedAt     DateTime               @updatedAt @map("updated_at")
  templateSteps ProcessTemplateStep[]
  routeSteps    WorkOrderProcessStep[]
  timeStandards ProcessTimeStandard[]

  @@index([isActive, sortOrder])
  @@index([stageGroup])
  @@map("process_definitions")
}

model ProcessTimeStandard {
  id                          String                 @id @default(uuid())
  processDefinitionId         String                 @map("process_definition_id")
  version                     Int
  timeBasis                   String                 @default("per_unit") @map("time_basis")
  unitLabel                   String                 @default("件") @map("unit_label")
  standardMillisecondsPerUnit Int                    @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                    @default(0) @map("setup_milliseconds")
  countsForEfficiency         Boolean                @default(true) @map("counts_for_efficiency")
  isCurrent                   Boolean                @default(true) @map("is_current")
  effectiveFrom               DateTime               @default(now()) @map("effective_from")
  remark                      String?
  createdById                 String?                @map("created_by_id")
  createdAt                   DateTime               @default(now()) @map("created_at")
  processDefinition           ProcessDefinition      @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  createdBy                   User?                  @relation("ProcessTimeStandardCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  routeSteps                  WorkOrderProcessStep[]

  @@unique([processDefinitionId, version])
  @@index([processDefinitionId, isCurrent])
  @@index([effectiveFrom])
  @@index([createdById])
  @@map("process_time_standards")
}

model ProcessTemplate {
  id          String                  @id @default(uuid())
  templateKey String                  @map("template_key")
  name        String
  version     Int                     @default(1)
  isDefault   Boolean                 @default(false) @map("is_default")
  isActive    Boolean                 @default(true) @map("is_active")
  createdById String?                 @map("created_by_id")
  createdAt   DateTime                @default(now()) @map("created_at")
  createdBy   User?                   @relation("ProcessTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  steps       ProcessTemplateStep[]
  routes      WorkOrderProcessRoute[]

  @@unique([templateKey, version])
  @@index([isDefault, isActive])
  @@index([createdAt])
  @@map("process_templates")
}

model ProcessTemplateStep {
  id                  String             @id @default(uuid())
  templateId          String             @map("template_id")
  processDefinitionId String?            @map("process_definition_id")
  processCode         String             @map("process_code")
  processName         String             @map("process_name")
  stageGroup          String             @map("stage_group")
  position            Int
  unitsPerProduct     Int                @default(1) @map("units_per_product")
  createdAt           DateTime           @default(now()) @map("created_at")
  template            ProcessTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)

  @@unique([templateId, position])
  @@index([processDefinitionId])
  @@map("process_template_steps")
}

model WorkOrderProcessRoute {
  id              String                 @id @default(uuid())
  workOrderId     String                 @unique @map("work_order_id")
  templateId      String?                @map("template_id")
  templateName    String                 @map("template_name")
  templateVersion Int                    @map("template_version")
  status          String                 @default("draft")
  version         Int                    @default(0)
  confirmedAt     DateTime?              @map("confirmed_at")
  confirmedById   String?                @map("confirmed_by_id")
  startedAt       DateTime?              @map("started_at")
  completedAt     DateTime?              @map("completed_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  workOrder       WorkOrder              @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  template        ProcessTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  confirmedBy     User?                  @relation("ProcessRouteConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  steps           WorkOrderProcessStep[]
  activities      ProcessRouteActivity[]

  @@index([status])
  @@index([templateId])
  @@index([updatedAt])
  @@map("work_order_process_routes")
}

model WorkOrderProcessStep {
  id                          String                 @id @default(uuid())
  routeId                     String                 @map("route_id")
  processDefinitionId         String?                @map("process_definition_id")
  processCode                 String                 @map("process_code")
  processName                 String                 @map("process_name")
  stageGroup                  String                 @map("stage_group")
  position                    Int
  standardTimeId              String?                @map("standard_time_id")
  standardVersion             Int?                   @map("standard_version")
  timeBasis                   String?                @map("time_basis")
  unitLabel                   String?                @map("unit_label")
  standardMillisecondsPerUnit Int?                   @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                    @default(0) @map("setup_milliseconds")
  unitsPerProduct             Int                    @default(1) @map("units_per_product")
  countsForEfficiency         Boolean                @default(true) @map("counts_for_efficiency")
  status                      String                 @default("pending")
  startedAt                   DateTime?              @map("started_at")
  completedAt                 DateTime?              @map("completed_at")
  completedById               String?                @map("completed_by_id")
  remark                      String?
  createdAt                   DateTime               @default(now()) @map("created_at")
  updatedAt                   DateTime               @updatedAt @map("updated_at")
  route                       WorkOrderProcessRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  processDefinition           ProcessDefinition?     @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)
  standardTime                ProcessTimeStandard?   @relation(fields: [standardTimeId], references: [id], onDelete: SetNull)
  completedBy                 User?                  @relation("ProcessStepCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  activities                  ProcessRouteActivity[]
  executions                  ProcessExecution[]

  @@unique([routeId, position])
  @@index([routeId, status])
  @@index([processDefinitionId])
  @@index([standardTimeId])
  @@index([completedById])
  @@map("work_order_process_steps")
}

model Employee {
  id         String             @id @default(uuid())
  employeeNo String             @unique @map("employee_no")
  name       String
  department String?
  team       String?
  isActive   Boolean            @default(true) @map("is_active")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")
  executions ProcessExecution[]

  @@index([isActive, employeeNo])
  @@index([name])
  @@index([department])
  @@index([team])
  @@map("employees")
}

model ProcessExecution {
  id                          String               @id @default(uuid())
  stepId                      String               @map("step_id")
  employeeId                  String               @map("employee_id")
  startedAt                   DateTime             @map("started_at")
  endedAt                     DateTime             @map("ended_at")
  breakMilliseconds           Int                  @default(0) @map("break_milliseconds")
  goodQty                     Int                  @map("good_qty")
  scrapQty                    Int                  @default(0) @map("scrap_qty")
  reworkQty                   Int                  @default(0) @map("rework_qty")
  timeBasis                   String               @default("per_unit") @map("time_basis")
  unitLabel                   String               @map("unit_label")
  standardMillisecondsPerUnit Int                  @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                  @default(0) @map("setup_milliseconds")
  unitsPerProduct             Int                  @default(1) @map("units_per_product")
  standardLaborMilliseconds   Int                  @map("standard_labor_milliseconds")
  actualLaborMilliseconds     Int                  @map("actual_labor_milliseconds")
  attainmentBasisPoints       Int                  @map("attainment_basis_points")
  countsForEfficiency         Boolean              @default(true) @map("counts_for_efficiency")
  source                      String               @default("manual")
  remark                      String?
  recordedById                String?              @map("recorded_by_id")
  createdAt                   DateTime             @default(now()) @map("created_at")
  updatedAt                   DateTime             @updatedAt @map("updated_at")
  voidedAt                    DateTime?            @map("voided_at")
  step                        WorkOrderProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  employee                    Employee             @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  recordedBy                  User?                @relation("ProcessExecutionRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([stepId, endedAt])
  @@index([employeeId, endedAt])
  @@index([endedAt])
  @@index([voidedAt])
  @@index([recordedById])
  @@map("process_executions")
}

model ProcessRouteActivity {
  id        String                @id @default(uuid())
  routeId   String                @map("route_id")
  stepId    String?               @map("step_id")
  action    String
  content   String?
  detail    Json?
  actorId   String?               @map("actor_id")
  createdAt DateTime              @default(now()) @map("created_at")
  route     WorkOrderProcessRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  step      WorkOrderProcessStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)
  actor     User?                 @relation("ProcessRouteActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([routeId, createdAt])
  @@index([stepId])
  @@index([actorId])
  @@index([action])
  @@map("process_route_activities")
}

model WarehouseMaterialTask {
  id            String                      @id @default(uuid())
  workOrderId   String                      @unique @map("work_order_id")
  status        String                      @default("pending")
  exceptionType String?                     @map("exception_type")
  exceptionNote String?                     @map("exception_note")
  expectedAt    DateTime?                   @map("expected_at")
  completedAt   DateTime?                   @map("completed_at")
  completedById String?                     @map("completed_by_id")
  updatedById   String?                     @map("updated_by_id")
  version       Int                         @default(0)
  createdAt     DateTime                    @default(now()) @map("created_at")
  updatedAt     DateTime                    @updatedAt @map("updated_at")
  workOrder     WorkOrder                   @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  completedBy   User?                       @relation("WarehouseTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  updatedBy     User?                       @relation("WarehouseTaskUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  activities    WarehouseMaterialActivity[]

  @@index([status])
  @@index([exceptionType])
  @@index([expectedAt])
  @@index([updatedAt])
  @@map("warehouse_material_tasks")
}

model WarehouseMaterialActivity {
  id         String                @id @default(uuid())
  taskId     String                @map("task_id")
  action     String
  fromStatus String?               @map("from_status")
  toStatus   String?               @map("to_status")
  content    String?
  detail     Json?
  actorId    String?               @map("actor_id")
  createdAt  DateTime              @default(now()) @map("created_at")
  task       WarehouseMaterialTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor      User?                 @relation("WarehouseActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("warehouse_material_activities")
}

model WorkOrderProgressLog {
  id              String    @id @default(uuid())
  workOrderId     String    @map("work_order_id")
  previousStage   String?   @map("previous_stage")
  stage           String
  completedQty    String?   @map("completed_qty")
  productionOwner String?   @map("production_owner")
  workstation     String?
  remark          String?
  createdBy       String?   @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId, createdAt])
  @@index([createdAt])
  @@map("work_order_progress_logs")
}

model ResourceCategory {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  sortOrder           Int                  @default(0) @map("sort_order")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  resourceFiles       ResourceFile[]
  drawingLibraryFiles DrawingLibraryFile[]

  @@map("resource_categories")
}

model ResourceFile {
  id                 String              @id @default(uuid())
  workOrderId        String              @map("work_order_id")
  categoryId         String              @map("category_id")
  originalName       String              @map("original_name")
  displayName        String?             @map("display_name")
  mimeType           String              @map("mime_type")
  fileType           String              @map("file_type")
  fileSize           Int                 @map("file_size")
  objectKey          String              @map("object_key")
  version            String              @default("V1.0")
  remark             String?
  status             String              @default("uploaded")
  uploadedById       String?             @map("uploaded_by_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  workOrder          WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  category           ResourceCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uploadedBy         User?               @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)
  drawingLibraryFile DrawingLibraryFile? @relation("DrawingLibraryFileSource")

  @@index([workOrderId])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([version])
  @@index([workOrderId, categoryId, status, deletedAt])
  @@index([objectKey])
  @@map("resource_files")
}

model DrawingLibraryItem {
  id              String               @id @default(uuid())
  customerName    String               @map("customer_name")
  customerCode    String?              @map("customer_code")
  productName     String?              @map("product_name")
  specification   String
  libraryKey      String               @unique @map("library_key")
  remark          String?
  deletedAt       DateTime?            @map("deleted_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  lastWorkOrderId String?              @map("last_work_order_id")
  lastImportedAt  DateTime?            @map("last_imported_at")
  files           DrawingLibraryFile[]
  workOrders      WorkOrder[]          @relation("DrawingLibraryWorkOrders")
  lastWorkOrder   WorkOrder?           @relation("LastDrawingLibraryWorkOrder", fields: [lastWorkOrderId], references: [id], onDelete: SetNull)

  @@index([customerName])
  @@index([customerCode])
  @@index([productName])
  @@index([specification])
  @@index([deletedAt])
  @@index([updatedAt])
  @@index([lastWorkOrderId])
  @@map("drawing_library_items")
}

model DrawingLibraryFile {
  id                   String             @id @default(uuid())
  libraryItemId        String             @map("library_item_id")
  categoryId           String             @map("category_id")
  originalName         String             @map("original_name")
  displayName          String?            @map("display_name")
  mimeType             String             @map("mime_type")
  size                 Int
  version              String             @default("V1.0")
  objectKey            String             @map("object_key")
  uploadedById         String?            @map("uploaded_by")
  sourceResourceFileId String?            @unique @map("source_resource_file_id")
  remark               String?
  deletedAt            DateTime?          @map("deleted_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  libraryItem          DrawingLibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  category             ResourceCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uploadedBy           User?              @relation("UploadedDrawingLibraryFiles", fields: [uploadedById], references: [id], onDelete: SetNull)
  sourceResourceFile   ResourceFile?      @relation("DrawingLibraryFileSource", fields: [sourceResourceFileId], references: [id], onDelete: SetNull)

  @@index([libraryItemId])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([version])
  @@index([objectKey])
  @@map("drawing_library_files")
}

model OperationLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("operation_logs")
}

model Issue {
  id                 String            @id @default(uuid())
  sequence           Int               @unique @default(autoincrement())
  title              String
  type               String            @default("production")
  priority           String            @default("normal")
  status             String            @default("pending")
  description        String?
  sourceType         String?           @map("source_type")
  sourceId           String?           @map("source_id")
  sourceCode         String?           @map("source_code")
  sourceRoute        String?           @map("source_route")
  sourceAlertCode    String?           @map("source_alert_code")
  sourceFingerprint  String?           @unique @map("source_fingerprint")
  workOrderId        String?           @map("work_order_id")
  reporterId         String?           @map("reporter_id")
  assigneeId         String?           @map("assignee_id")
  dueAt              DateTime?         @map("due_at")
  rootCause          String?           @map("root_cause")
  solution           String?
  verificationResult String?           @map("verification_result")
  resolvedAt         DateTime?         @map("resolved_at")
  verifiedAt         DateTime?         @map("verified_at")
  closedAt           DateTime?         @map("closed_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  deletedAt          DateTime?         @map("deleted_at")
  workOrder          WorkOrder?        @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  reporter           User?             @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assignee           User?             @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  activities         IssueActivity[]
  attachments        IssueAttachment[]
  changeRequests     ChangeRequest[]

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([workOrderId])
  @@index([sourceType, sourceId])
  @@index([dueAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("issues")
}

model IssueActivity {
  id         String   @id @default(uuid())
  issueId    String   @map("issue_id")
  action     String
  content    String?
  fromStatus String?  @map("from_status")
  toStatus   String?  @map("to_status")
  actorId    String?  @map("actor_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  issue      Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  actor      User?    @relation("IssueActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([issueId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("issue_activities")
}

model IssueAttachment {
  id           String    @id @default(uuid())
  issueId      String    @map("issue_id")
  objectKey    String    @unique @map("object_key")
  originalName String    @map("original_name")
  displayName  String?   @map("display_name")
  mimeType     String    @map("mime_type")
  fileType     String    @map("file_type")
  size         BigInt
  uploadedById String?   @map("uploaded_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  issue        Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploadedBy   User?     @relation("IssueAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([issueId, createdAt])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("issue_attachments")
}

model ChangeRequest {
  id                   String             @id @default(uuid())
  sequence             Int                @unique @default(autoincrement())
  title                String
  type                 String             @default("drawing")
  priority             String             @default("normal")
  status               String             @default("draft")
  reason               String?
  description          String?
  impactAreas          String[]           @default([]) @map("impact_areas")
  impactScope          String?            @map("impact_scope")
  implementationPlan   String?            @map("implementation_plan")
  implementationResult String?            @map("implementation_result")
  validationResult     String?            @map("validation_result")
  rollbackPlan         String?            @map("rollback_plan")
  sourceIssueId        String?            @map("source_issue_id")
  workOrderId          String?            @map("work_order_id")
  requesterId          String?            @map("requester_id")
  ownerId              String?            @map("owner_id")
  dueAt                DateTime?          @map("due_at")
  effectiveAt          DateTime?          @map("effective_at")
  version              Int                @default(0)
  closedAt             DateTime?          @map("closed_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  deletedAt            DateTime?          @map("deleted_at")
  sourceIssue          Issue?             @relation(fields: [sourceIssueId], references: [id], onDelete: SetNull)
  workOrder            WorkOrder?         @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  requester            User?              @relation("ChangeRequester", fields: [requesterId], references: [id], onDelete: SetNull)
  owner                User?              @relation("ChangeOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities           ChangeActivity[]
  attachments          ChangeAttachment[]

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([ownerId])
  @@index([requesterId])
  @@index([workOrderId])
  @@index([sourceIssueId])
  @@index([dueAt])
  @@index([updatedAt])
  @@index([deletedAt])
  @@map("change_requests")
}

model ChangeActivity {
  id              String        @id @default(uuid())
  changeRequestId String        @map("change_request_id")
  action          String
  content         String?
  fromStatus      String?       @map("from_status")
  toStatus        String?       @map("to_status")
  actorId         String?       @map("actor_id")
  detail          Json?
  createdAt       DateTime      @default(now()) @map("created_at")
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  actor           User?         @relation("ChangeActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([changeRequestId, createdAt])
  @@index([actorId])
  @@index([action])
  @@map("change_activities")
}

model ChangeAttachment {
  id              String        @id @default(uuid())
  changeRequestId String        @map("change_request_id")
  objectKey       String        @unique @map("object_key")
  originalName    String        @map("original_name")
  displayName     String?       @map("display_name")
  mimeType        String        @map("mime_type")
  fileType        String        @map("file_type")
  size            BigInt
  uploadedById    String?       @map("uploaded_by_id")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  deletedAt       DateTime?     @map("deleted_at")
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  uploadedBy      User?         @relation("ChangeAttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([changeRequestId, createdAt])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("change_attachments")
}

model ConnectorParameter {
  id                     String                           @id @default(cuid())
  rowNo                  Int?                             @map("row_no")
  model                  String?
  outerPeelMm            String?                          @map("outer_peel_mm")
  innerPeelMm            String?                          @map("inner_peel_mm")
  insertionLengthMm      String?                          @map("insertion_length_mm")
  remark                 String?
  isHighlighted          Boolean                          @default(false) @map("is_highlighted")
  createdBy              String?                          @map("created_by")
  updatedBy              String?                          @map("updated_by")
  createdAt              DateTime                         @default(now()) @map("created_at")
  updatedAt              DateTime                         @updatedAt @map("updated_at")
  deletedAt              DateTime?                        @map("deleted_at")
  importBatchId          String?                          @map("import_batch_id")
  importBatch            ConnectorParameterImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  assemblyManualBindings ConnectorAssemblyManualBinding[]

  @@index([rowNo])
  @@index([model])
  @@index([isHighlighted])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([importBatchId])
  @@map("connector_parameters")
}

model ConnectorAssemblyManual {
  id           String                              @id @default(cuid())
  title        String
  manufacturer String?
  family       String?
  documentNo   String?                             @map("document_no")
  summary      String?
  keywords     String?
  createdBy    String?                             @map("created_by")
  deletedAt    DateTime?                           @map("deleted_at")
  createdAt    DateTime                            @default(now()) @map("created_at")
  updatedAt    DateTime                            @updatedAt @map("updated_at")
  versions     ConnectorAssemblyManualVersion[]
  bindings     ConnectorAssemblyManualBinding[]
  importItems  ConnectorAssemblyManualImportItem[]

  @@index([title])
  @@index([manufacturer])
  @@index([family])
  @@index([documentNo])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("connector_assembly_manuals")
}

model ConnectorAssemblyManualVersion {
  id            String                              @id @default(cuid())
  manualId      String                              @map("manual_id")
  revision      String
  issuedAt      DateTime?                           @map("issued_at")
  pageCount     Int?                                @map("page_count")
  fileMode      String                              @map("file_mode")
  isLatest      Boolean                             @default(false) @map("is_latest")
  status        String?
  tocJson       Json?                               @map("toc_json")
  searchText    String?                             @map("search_text") @db.Text
  detectedTitle String?                             @map("detected_title")
  parseStatus   String?                             @map("parse_status")
  parseWarnings Json?                               @map("parse_warnings")
  remark        String?
  createdBy     String?                             @map("created_by")
  deletedAt     DateTime?                           @map("deleted_at")
  createdAt     DateTime                            @default(now()) @map("created_at")
  updatedAt     DateTime                            @updatedAt @map("updated_at")
  manual        ConnectorAssemblyManual             @relation(fields: [manualId], references: [id], onDelete: Cascade)
  assets        ConnectorAssemblyManualAsset[]
  importItems   ConnectorAssemblyManualImportItem[]

  @@unique([manualId, revision])
  @@index([manualId, deletedAt])
  @@index([isLatest])
  @@index([issuedAt])
  @@index([deletedAt])
  @@index([parseStatus])
  @@map("connector_assembly_manual_versions")
}

model ConnectorAssemblyManualAsset {
  id           String                         @id @default(cuid())
  versionId    String                         @map("version_id")
  assetType    String                         @map("asset_type")
  originalName String                         @map("original_name")
  displayName  String?                        @map("display_name")
  mimeType     String                         @map("mime_type")
  size         Int
  objectKey    String                         @map("object_key")
  relativePath String?                        @map("relative_path")
  fileHash     String?                        @map("file_hash")
  pageNo       Int?                           @map("page_no")
  sortOrder    Int                            @default(0) @map("sort_order")
  isPrimary    Boolean                        @default(false) @map("is_primary")
  uploadedBy   String?                        @map("uploaded_by")
  deletedAt    DateTime?                      @map("deleted_at")
  createdAt    DateTime                       @default(now()) @map("created_at")
  updatedAt    DateTime                       @updatedAt @map("updated_at")
  version      ConnectorAssemblyManualVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId, deletedAt])
  @@index([sortOrder])
  @@index([objectKey])
  @@index([fileHash])
  @@index([relativePath])
  @@index([deletedAt])
  @@map("connector_assembly_manual_assets")
}

model ConnectorAssemblyManualBinding {
  id                   String                  @id @default(cuid())
  manualId             String                  @map("manual_id")
  connectorParameterId String                  @map("connector_parameter_id")
  createdAt            DateTime                @default(now()) @map("created_at")
  manual               ConnectorAssemblyManual @relation(fields: [manualId], references: [id], onDelete: Cascade)
  connectorParameter   ConnectorParameter      @relation(fields: [connectorParameterId], references: [id], onDelete: Cascade)

  @@unique([manualId, connectorParameterId])
  @@index([manualId])
  @@index([connectorParameterId])
  @@map("connector_assembly_manual_bindings")
}

model ConnectorAssemblyManualImportBatch {
  id             String                              @id @default(cuid())
  sourceName     String?                             @map("source_name")
  totalCount     Int                                 @map("total_count")
  readyCount     Int                                 @default(0) @map("ready_count")
  successCount   Int                                 @default(0) @map("success_count")
  duplicateCount Int                                 @default(0) @map("duplicate_count")
  failedCount    Int                                 @default(0) @map("failed_count")
  skippedCount   Int                                 @default(0) @map("skipped_count")
  status         String                              @default("preview")
  createdBy      String?                             @map("created_by")
  startedAt      DateTime?                           @map("started_at")
  completedAt    DateTime?                           @map("completed_at")
  createdAt      DateTime                            @default(now()) @map("created_at")
  updatedAt      DateTime                            @updatedAt @map("updated_at")
  items          ConnectorAssemblyManualImportItem[]

  @@index([status])
  @@index([createdAt])
  @@map("connector_assembly_manual_import_batches")
}

model ConnectorAssemblyManualImportItem {
  id            String                             @id @default(cuid())
  batchId       String                             @map("batch_id")
  clientId      String                             @map("client_id")
  fileName      String                             @map("file_name")
  relativePath  String?                            @map("relative_path")
  fileMode      String                             @map("file_mode")
  fileHash      String?                            @map("file_hash")
  action        String
  status        String                             @default("pending")
  title         String
  revision      String?
  manualId      String?                            @map("manual_id")
  versionId     String?                            @map("version_id")
  pageCount     Int?                               @map("page_count")
  detectedTitle String?                            @map("detected_title")
  errorMessage  String?                            @map("error_message")
  warningsJson  Json?                              @map("warnings_json")
  metadataJson  Json?                              @map("metadata_json")
  attemptCount  Int                                @default(0) @map("attempt_count")
  createdAt     DateTime                           @default(now()) @map("created_at")
  updatedAt     DateTime                           @updatedAt @map("updated_at")
  batch         ConnectorAssemblyManualImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  manual        ConnectorAssemblyManual?           @relation(fields: [manualId], references: [id], onDelete: SetNull)
  version       ConnectorAssemblyManualVersion?    @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@unique([batchId, clientId])
  @@index([batchId, status])
  @@index([fileHash])
  @@index([manualId])
  @@index([versionId])
  @@map("connector_assembly_manual_import_items")
}

model ConnectorParameterImportBatch {
  id                String               @id @default(cuid())
  sourceType        String               @map("source_type")
  fileName          String?              @map("file_name")
  totalRows         Int                  @map("total_rows")
  readyCount        Int                  @default(0) @map("ready_count")
  duplicateCount    Int                  @default(0) @map("duplicate_count")
  invalidCount      Int                  @default(0) @map("invalid_count")
  skippedCount      Int                  @default(0) @map("skipped_count")
  insertedCount     Int                  @default(0) @map("inserted_count")
  duplicateStrategy String               @map("duplicate_strategy")
  createdBy         String?              @map("created_by")
  createdAt         DateTime             @default(now()) @map("created_at")
  rolledBackAt      DateTime?            @map("rolled_back_at")
  rolledBackBy      String?              @map("rolled_back_by")
  summaryJson       Json?                @map("summary_json")
  parameters        ConnectorParameter[]

  @@index([createdAt])
  @@index([rolledBackAt])
  @@map("connector_parameter_import_batches")
}

model DataChangeSnapshot {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  changedBy  String?  @map("changed_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("data_change_snapshots")
}

model ConnectorParameterFile {
  id           String    @id @default(cuid())
  originalName String    @map("original_name")
  displayName  String?   @map("display_name")
  mimeType     String    @map("mime_type")
  fileType     String    @map("file_type")
  fileSize     Int       @map("file_size")
  objectKey    String    @map("object_key")
  uploadedBy   String?   @map("uploaded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@index([createdAt])
  @@map("connector_parameter_files")
}
