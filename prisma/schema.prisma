generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid())
  username            String               @unique
  passwordHash        String               @map("password_hash")
  displayName         String               @map("display_name")
  isActive            Boolean              @default(true) @map("is_active")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  uploadedFiles       ResourceFile[]       @relation("UploadedFiles")
  drawingLibraryFiles DrawingLibraryFile[] @relation("UploadedDrawingLibraryFiles")
  operationLogs       OperationLog[]

  @@map("users")
}

model WorkOrder {
  id                      String               @id @default(uuid())
  code                    String               @unique
  customerName            String?              @map("customer_name")
  productName             String               @map("product_name")
  stage                   String
  progress                Int                  @default(0)
  priority                String               @default("normal")
  status                  String               @default("processing")
  plannedAt               DateTime?            @map("planned_at")
  remark                  String?
  sourceOrderNo           String?              @map("source_order_no")
  salesperson             String?
  orderDate               DateTime?            @map("order_date")
  customerLevel           String?              @map("customer_level")
  specification           String?
  processName             String?              @map("process_name")
  uncompletedQty          String?              @map("uncompleted_qty")
  unitWorkHours           String?              @map("unit_work_hours")
  totalWorkHours          String?              @map("total_work_hours")
  drawingStatus           String?              @map("drawing_status")
  deliveryDay             String?              @map("delivery_day")
  materialStatus          String?              @map("material_status")
  drawingIssuedAt         DateTime?            @map("drawing_issued_at")
  drawingIssueNote        String?              @map("drawing_issue_note")
  importBatchId           String?              @map("import_batch_id")
  sourceSheetName         String?              @map("source_sheet_name")
  sourceRowNo             Int?                 @map("source_row_no")
  planType                String?              @map("plan_type")
  weekStartDate           DateTime?            @map("week_start_date")
  weekEndDate             DateTime?            @map("week_end_date")
  planActive              Boolean              @default(true) @map("plan_active")
  planClearedAt           DateTime?            @map("plan_cleared_at")
  planClearedBy           String?              @map("plan_cleared_by")
  libraryKey              String?              @map("library_key")
  drawingLibraryItemId    String?              @map("drawing_library_item_id")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")
  deletedAt               DateTime?            @map("deleted_at")
  resourceFiles           ResourceFile[]
  drawingLibraryItem      DrawingLibraryItem?  @relation("DrawingLibraryWorkOrders", fields: [drawingLibraryItemId], references: [id], onDelete: SetNull)
  lastDrawingLibraryItems DrawingLibraryItem[] @relation("LastDrawingLibraryWorkOrder")

  @@index([code])
  @@index([productName])
  @@index([customerName])
  @@index([stage])
  @@index([plannedAt])
  @@index([createdAt])
  @@index([priority])
  @@index([status])
  @@index([deletedAt])
  @@index([sourceOrderNo])
  @@index([salesperson])
  @@index([specification])
  @@index([importBatchId])
  @@index([sourceRowNo])
  @@index([planType])
  @@index([weekStartDate])
  @@index([planActive])
  @@index([libraryKey])
  @@index([drawingLibraryItemId])
  @@map("work_orders")
}

model ResourceCategory {
  id                  String               @id @default(uuid())
  name                String
  code                String               @unique
  sortOrder           Int                  @default(0) @map("sort_order")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  resourceFiles       ResourceFile[]
  drawingLibraryFiles DrawingLibraryFile[]

  @@map("resource_categories")
}

model ResourceFile {
  id                 String              @id @default(uuid())
  workOrderId        String              @map("work_order_id")
  categoryId         String              @map("category_id")
  originalName       String              @map("original_name")
  displayName        String?             @map("display_name")
  mimeType           String              @map("mime_type")
  fileType           String              @map("file_type")
  fileSize           Int                 @map("file_size")
  objectKey          String              @map("object_key")
  version            String              @default("V1.0")
  remark             String?
  status             String              @default("uploaded")
  uploadedById       String?             @map("uploaded_by_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  workOrder          WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  category           ResourceCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uploadedBy         User?               @relation("UploadedFiles", fields: [uploadedById], references: [id], onDelete: SetNull)
  drawingLibraryFile DrawingLibraryFile? @relation("DrawingLibraryFileSource")

  @@index([workOrderId])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([version])
  @@index([workOrderId, categoryId, status, deletedAt])
  @@index([objectKey])
  @@map("resource_files")
}

model DrawingLibraryItem {
  id              String               @id @default(uuid())
  customerName    String               @map("customer_name")
  customerCode    String?              @map("customer_code")
  productName     String?              @map("product_name")
  specification   String
  libraryKey      String               @unique @map("library_key")
  remark          String?
  deletedAt       DateTime?            @map("deleted_at")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  lastWorkOrderId String?              @map("last_work_order_id")
  lastImportedAt  DateTime?            @map("last_imported_at")
  files           DrawingLibraryFile[]
  workOrders      WorkOrder[]          @relation("DrawingLibraryWorkOrders")
  lastWorkOrder   WorkOrder?           @relation("LastDrawingLibraryWorkOrder", fields: [lastWorkOrderId], references: [id], onDelete: SetNull)

  @@index([customerName])
  @@index([customerCode])
  @@index([productName])
  @@index([specification])
  @@index([deletedAt])
  @@index([updatedAt])
  @@index([lastWorkOrderId])
  @@map("drawing_library_items")
}

model DrawingLibraryFile {
  id                   String             @id @default(uuid())
  libraryItemId        String             @map("library_item_id")
  categoryId           String             @map("category_id")
  originalName         String             @map("original_name")
  displayName          String?            @map("display_name")
  mimeType             String             @map("mime_type")
  size                 Int
  version              String             @default("V1.0")
  objectKey            String             @map("object_key")
  uploadedById         String?            @map("uploaded_by")
  sourceResourceFileId String?            @unique @map("source_resource_file_id")
  remark               String?
  deletedAt            DateTime?          @map("deleted_at")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  libraryItem          DrawingLibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  category             ResourceCategory   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uploadedBy           User?              @relation("UploadedDrawingLibraryFiles", fields: [uploadedById], references: [id], onDelete: SetNull)
  sourceResourceFile   ResourceFile?      @relation("DrawingLibraryFileSource", fields: [sourceResourceFileId], references: [id], onDelete: SetNull)

  @@index([libraryItemId])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([version])
  @@index([objectKey])
  @@map("drawing_library_files")
}

model OperationLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("operation_logs")
}

model ConnectorParameter {
  id                String                         @id @default(cuid())
  rowNo             Int?                           @map("row_no")
  model             String?
  outerPeelMm       String?                        @map("outer_peel_mm")
  innerPeelMm       String?                        @map("inner_peel_mm")
  insertionLengthMm String?                        @map("insertion_length_mm")
  remark            String?
  isHighlighted     Boolean                        @default(false) @map("is_highlighted")
  createdBy         String?                        @map("created_by")
  updatedBy         String?                        @map("updated_by")
  createdAt         DateTime                       @default(now()) @map("created_at")
  updatedAt         DateTime                       @updatedAt @map("updated_at")
  deletedAt         DateTime?                      @map("deleted_at")
  importBatchId     String?                        @map("import_batch_id")
  importBatch       ConnectorParameterImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([rowNo])
  @@index([model])
  @@index([isHighlighted])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([importBatchId])
  @@map("connector_parameters")
}

model ConnectorParameterImportBatch {
  id                String               @id @default(cuid())
  sourceType        String               @map("source_type")
  fileName          String?              @map("file_name")
  totalRows         Int                  @map("total_rows")
  readyCount        Int                  @default(0) @map("ready_count")
  duplicateCount    Int                  @default(0) @map("duplicate_count")
  invalidCount      Int                  @default(0) @map("invalid_count")
  skippedCount      Int                  @default(0) @map("skipped_count")
  insertedCount     Int                  @default(0) @map("inserted_count")
  duplicateStrategy String               @map("duplicate_strategy")
  createdBy         String?              @map("created_by")
  createdAt         DateTime             @default(now()) @map("created_at")
  rolledBackAt      DateTime?            @map("rolled_back_at")
  rolledBackBy      String?              @map("rolled_back_by")
  summaryJson       Json?                @map("summary_json")
  parameters        ConnectorParameter[]

  @@index([createdAt])
  @@index([rolledBackAt])
  @@map("connector_parameter_import_batches")
}

model DataChangeSnapshot {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  changedBy  String?  @map("changed_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("data_change_snapshots")
}

model ConnectorParameterFile {
  id           String    @id @default(cuid())
  originalName String    @map("original_name")
  displayName  String?   @map("display_name")
  mimeType     String    @map("mime_type")
  fileType     String    @map("file_type")
  fileSize     Int       @map("file_size")
  objectKey    String    @map("object_key")
  uploadedBy   String?   @map("uploaded_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@index([createdAt])
  @@map("connector_parameter_files")
}
