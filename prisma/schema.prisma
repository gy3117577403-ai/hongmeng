generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkOrderBranchType {
  REWORK
  SCRAP_REPLENISH
  QUALITY_PENDING

  @@map("work_order_branch_type")
}

enum WorkOrderBranchStatus {
  OPEN
  RELEASED
  IN_PROGRESS
  QUALITY_PENDING
  RESOLVED
  CANCELLED

  @@map("work_order_branch_status")
}

enum ProcessDefectDisposition {
  REWORK
  SCRAP_REPLENISH
  QUALITY_PENDING

  @@map("process_defect_disposition")
}

enum ProcessMovementType {
  GOOD_TRANSFER
  FINISHED_GOOD
  REWORK_SPLIT
  SCRAP_REPLENISH_SPLIT
  QUALITY_HOLD
  REWORK_RETURN
  SCRAP
  ADJUSTMENT
  REVERSAL

  @@map("process_movement_type")
}

enum ProcessLaborPoolStatus {
  OPEN
  PARTIAL
  EXHAUSTED
  LOCKED
  VOIDED

  @@map("process_labor_pool_status")
}

enum ProcessLaborClaimStatus {
  ACTIVE
  VOIDED
  REVERSAL

  @@map("process_labor_claim_status")
}

enum LaborAccessRole {
  ADMIN
  TEAM_LEAD
  EMPLOYEE

  @@map("labor_access_role")
}

model User {
  id                             String                      @id @default(uuid())
  username                       String                      @unique
  passwordHash                   String                      @map("password_hash")
  displayName                    String                      @map("display_name")
  isActive                       Boolean                     @default(true) @map("is_active")
  laborRole                      LaborAccessRole             @default(EMPLOYEE) @map("labor_role")
  employeeId                     String?                     @unique @map("employee_id")
  createdAt                      DateTime                    @default(now()) @map("created_at")
  updatedAt                      DateTime                    @updatedAt @map("updated_at")
  employee                       Employee?                   @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  uploadedFiles                  ResourceFile[]              @relation("UploadedFiles")
  drawingLibraryFiles            DrawingLibraryFile[]        @relation("UploadedDrawingLibraryFiles")
  operationLogs                  OperationLog[]
  reportedIssues                 Issue[]                     @relation("IssueReporter")
  assignedIssues                 Issue[]                     @relation("IssueAssignee")
  issueActivities                IssueActivity[]             @relation("IssueActivityActor")
  issueAttachments               IssueAttachment[]           @relation("IssueAttachmentUploader")
  requestedChanges               ChangeRequest[]             @relation("ChangeRequester")
  ownedChanges                   ChangeRequest[]             @relation("ChangeOwner")
  changeActivities               ChangeActivity[]            @relation("ChangeActivityActor")
  changeAttachments              ChangeAttachment[]          @relation("ChangeAttachmentUploader")
  completedMaterialTasks         WarehouseMaterialTask[]     @relation("WarehouseTaskCompletedBy")
  updatedMaterialTasks           WarehouseMaterialTask[]     @relation("WarehouseTaskUpdatedBy")
  warehouseActivities            WarehouseMaterialActivity[] @relation("WarehouseActivityActor")
  createdProcessTemplates        ProcessTemplate[]           @relation("ProcessTemplateCreatedBy")
  createdProcessTimeStandards    ProcessTimeStandard[]       @relation("ProcessTimeStandardCreatedBy")
  createdProductTimeProfiles     ProductTimeProfile[]        @relation("ProductTimeProfileCreatedBy")
  updatedProductTimeProfiles     ProductTimeProfile[]        @relation("ProductTimeProfileUpdatedBy")
  publishedProductTimeProfiles   ProductTimeProfile[]        @relation("ProductTimeProfilePublishedBy")
  createdProductQuotationTimes   ProductQuotationTime[]      @relation("ProductQuotationTimeCreatedBy")
  confirmedProcessRoutes         WorkOrderProcessRoute[]     @relation("ProcessRouteConfirmedBy")
  completedProcessSteps          WorkOrderProcessStep[]      @relation("ProcessStepCompletedBy")
  recordedProcessExecutions      ProcessExecution[]          @relation("ProcessExecutionRecordedBy")
  processRouteActivities         ProcessRouteActivity[]      @relation("ProcessRouteActivityActor")
  createdKnowledgeArticles       KnowledgeArticle[]          @relation("KnowledgeArticleCreatedBy")
  updatedKnowledgeArticles       KnowledgeArticle[]          @relation("KnowledgeArticleUpdatedBy")
  knowledgeAttachments           KnowledgeAttachment[]       @relation("KnowledgeAttachmentUploader")
  createdAttendanceRecords       AttendanceRecord[]          @relation("AttendanceRecordCreatedBy")
  updatedAttendanceRecords       AttendanceRecord[]          @relation("AttendanceRecordUpdatedBy")
  confirmedAttendanceRecords     AttendanceRecord[]          @relation("AttendanceRecordConfirmedBy")
  createdAbnormalTimeEvents      AbnormalTimeEvent[]         @relation("AbnormalTimeEventCreatedBy")
  updatedAbnormalTimeEvents      AbnormalTimeEvent[]         @relation("AbnormalTimeEventUpdatedBy")
  qualityConfirmedAbnormalEvents AbnormalTimeEvent[]         @relation("AbnormalTimeEventQualityConfirmedBy")
  resolvedAbnormalTimeEvents     AbnormalTimeEvent[]         @relation("AbnormalTimeEventResolvedBy")
  createdProductionPlanOrders    ProductionPlanOrder[]       @relation("ProductionPlanOrderCreatedBy")
  updatedProductionPlanOrders    ProductionPlanOrder[]       @relation("ProductionPlanOrderUpdatedBy")
  releasedProductionPlanBatches  ProductionPlanBatch[]       @relation("ProductionPlanBatchReleasedBy")
  activatedProductionPlanBatches ProductionPlanBatch[]       @relation("ProductionPlanBatchActivatedBy")
  productionPlanChanges          ProductionPlanChange[]      @relation("ProductionPlanChangeActor")
  createdProcessCompletions      ProcessCompletion[]         @relation("ProcessCompletionCreatedBy")
  voidedProcessCompletions       ProcessCompletion[]         @relation("ProcessCompletionVoidedBy")
  claimedProcessLaborClaims      ProcessLaborClaim[]         @relation("ProcessLaborClaimClaimedBy")
  voidedProcessLaborClaims       ProcessLaborClaim[]         @relation("ProcessLaborClaimVoidedBy")

  @@map("users")
}

model WorkOrder {
  id                      String                    @id @default(uuid())
  code                    String                    @unique
  customerName            String?                   @map("customer_name")
  productName             String                    @map("product_name")
  stage                   String
  progress                Int                       @default(0)
  priority                String                    @default("normal")
  status                  String                    @default("processing")
  plannedAt               DateTime?                 @map("planned_at")
  remark                  String?
  sourceOrderNo           String?                   @map("source_order_no")
  salesperson             String?
  orderDate               DateTime?                 @map("order_date")
  customerLevel           String?                   @map("customer_level")
  specification           String?
  processName             String?                   @map("process_name")
  uncompletedQty          String?                   @map("uncompleted_qty")
  productionTargetQty     Int?                      @map("production_target_qty")
  unitWorkHours           String?                   @map("unit_work_hours")
  totalWorkHours          String?                   @map("total_work_hours")
  drawingStatus           String?                   @map("drawing_status")
  deliveryDay             String?                   @map("delivery_day")
  materialStatus          String?                   @map("material_status")
  drawingIssuedAt         DateTime?                 @map("drawing_issued_at")
  drawingIssueNote        String?                   @map("drawing_issue_note")
  importBatchId           String?                   @map("import_batch_id")
  sourceSheetName         String?                   @map("source_sheet_name")
  sourceRowNo             Int?                      @map("source_row_no")
  planType                String?                   @map("plan_type")
  weekStartDate           DateTime?                 @map("week_start_date")
  weekEndDate             DateTime?                 @map("week_end_date")
  planActive              Boolean                   @default(true) @map("plan_active")
  planClearedAt           DateTime?                 @map("plan_cleared_at")
  planClearedBy           String?                   @map("plan_cleared_by")
  libraryKey              String?                   @map("library_key")
  drawingLibraryItemId    String?                   @map("drawing_library_item_id")
  productionOwner         String?                   @map("production_owner")
  workstation             String?
  completedQty            String?                   @map("completed_qty")
  frontendTransferredQty  Int?                      @map("frontend_transferred_qty")
  executionVersion        Int                       @default(0) @map("execution_version")
  parentWorkOrderId       String?                   @map("parent_work_order_id")
  rootWorkOrderId         String?                   @map("root_work_order_id")
  branchType              WorkOrderBranchType?      @map("branch_type")
  branchStatus            WorkOrderBranchStatus?    @map("branch_status")
  originCompletionId      String?                   @unique @map("origin_completion_id")
  originStepId            String?                   @map("origin_step_id")
  rejoinStepId            String?                   @map("rejoin_step_id")
  branchSequence          Int?                      @map("branch_sequence")
  startedAt               DateTime?                 @map("started_at")
  completedAt             DateTime?                 @map("completed_at")
  lastProgressAt          DateTime?                 @map("last_progress_at")
  latestProgressRemark    String?                   @map("latest_progress_remark")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  deletedAt               DateTime?                 @map("deleted_at")
  resourceFiles           ResourceFile[]
  drawingLibraryItem      DrawingLibraryItem?       @relation("DrawingLibraryWorkOrders", fields: [drawingLibraryItemId], references: [id], onDelete: SetNull)
  lastDrawingLibraryItems DrawingLibraryItem[]      @relation("LastDrawingLibraryWorkOrder")
  progressLogs            WorkOrderProgressLog[]
  issues                  Issue[]
  changeRequests          ChangeRequest[]
  materialTask            WarehouseMaterialTask?
  processRoute            WorkOrderProcessRoute?
  abnormalTimeEvents      AbnormalTimeEvent[]
  productionPlanBatch     ProductionPlanBatch?
  parentWorkOrder         WorkOrder?                @relation("WorkOrderBranchParent", fields: [parentWorkOrderId], references: [id], onDelete: SetNull)
  branchWorkOrders        WorkOrder[]               @relation("WorkOrderBranchParent")
  rootWorkOrder           WorkOrder?                @relation("WorkOrderBranchRoot", fields: [rootWorkOrderId], references: [id], onDelete: SetNull)
  rootBranchWorkOrders    WorkOrder[]               @relation("WorkOrderBranchRoot")
  originCompletion        ProcessCompletion?        @relation("CompletionBranchWorkOrder", fields: [originCompletionId], references: [id], onDelete: SetNull)
  originStep              WorkOrderProcessStep?     @relation("WorkOrderBranchOriginStep", fields: [originStepId], references: [id], onDelete: SetNull)
  rejoinStep              WorkOrderProcessStep?     @relation("WorkOrderBranchRejoinStep", fields: [rejoinStepId], references: [id], onDelete: SetNull)
  processCompletions      ProcessCompletion[]       @relation("CompletionWorkOrder")
  quantityMovements       ProcessQuantityMovement[] @relation("MovementWorkOrder")
  branchQuantityMovements ProcessQuantityMovement[] @relation("MovementBranchWorkOrder")
  processLaborPools       ProcessLaborPool[]

  @@unique([parentWorkOrderId, branchSequence])
  @@index([code])
  @@index([productName])
  @@index([customerName])
  @@index([stage])
  @@index([plannedAt])
  @@index([createdAt])
  @@index([priority])
  @@index([status])
  @@index([deletedAt])
  @@index([sourceOrderNo])
  @@index([salesperson])
  @@index([specification])
  @@index([importBatchId])
  @@index([sourceRowNo])
  @@index([planType])
  @@index([weekStartDate])
  @@index([planActive])
  @@index([libraryKey])
  @@index([drawingLibraryItemId])
  @@index([productionOwner])
  @@index([workstation])
  @@index([lastProgressAt])
  @@index([parentWorkOrderId])
  @@index([rootWorkOrderId])
  @@index([branchType, branchStatus])
  @@index([originStepId])
  @@index([rejoinStepId])
  @@map("work_orders")
}

model ProcessDefinition {
  id                 String                    @id @default(uuid())
  code               String                    @unique
  name               String
  stageGroup         String                    @map("stage_group")
  isActive           Boolean                   @default(true) @map("is_active")
  sortOrder          Int                       @default(0) @map("sort_order")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  templateSteps      ProcessTemplateStep[]
  routeSteps         WorkOrderProcessStep[]
  timeStandards      ProcessTimeStandard[]
  productTimeEntries ProductProcessTimeEntry[]

  @@index([isActive, sortOrder])
  @@index([stageGroup])
  @@map("process_definitions")
}

model ProcessTimeStandard {
  id                          String                 @id @default(uuid())
  processDefinitionId         String                 @map("process_definition_id")
  version                     Int
  timeBasis                   String                 @default("per_unit") @map("time_basis")
  unitLabel                   String                 @default("件") @map("unit_label")
  standardMillisecondsPerUnit Int                    @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                    @default(0) @map("setup_milliseconds")
  countsForEfficiency         Boolean                @default(true) @map("counts_for_efficiency")
  isCurrent                   Boolean                @default(true) @map("is_current")
  effectiveFrom               DateTime               @default(now()) @map("effective_from")
  remark                      String?
  createdById                 String?                @map("created_by_id")
  createdAt                   DateTime               @default(now()) @map("created_at")
  processDefinition           ProcessDefinition      @relation(fields: [processDefinitionId], references: [id], onDelete: Cascade)
  createdBy                   User?                  @relation("ProcessTimeStandardCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  routeSteps                  WorkOrderProcessStep[]

  @@unique([processDefinitionId, version])
  @@index([processDefinitionId, isCurrent])
  @@index([effectiveFrom])
  @@index([createdById])
  @@map("process_time_standards")
}

model ProcessTemplate {
  id          String                  @id @default(uuid())
  templateKey String                  @map("template_key")
  name        String
  version     Int                     @default(1)
  isDefault   Boolean                 @default(false) @map("is_default")
  isActive    Boolean                 @default(true) @map("is_active")
  createdById String?                 @map("created_by_id")
  createdAt   DateTime                @default(now()) @map("created_at")
  createdBy   User?                   @relation("ProcessTemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  steps       ProcessTemplateStep[]
  routes      WorkOrderProcessRoute[]

  @@unique([templateKey, version])
  @@index([isDefault, isActive])
  @@index([createdAt])
  @@map("process_templates")
}

model ProcessTemplateStep {
  id                  String             @id @default(uuid())
  templateId          String             @map("template_id")
  processDefinitionId String?            @map("process_definition_id")
  processCode         String             @map("process_code")
  processName         String             @map("process_name")
  stageGroup          String             @map("stage_group")
  position            Int
  unitsPerProduct     Int                @default(1) @map("units_per_product")
  createdAt           DateTime           @default(now()) @map("created_at")
  template            ProcessTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  processDefinition   ProcessDefinition? @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)

  @@unique([templateId, position])
  @@index([processDefinitionId])
  @@map("process_template_steps")
}

model WorkOrderProcessRoute {
  id                        String                 @id @default(uuid())
  workOrderId               String                 @unique @map("work_order_id")
  templateId                String?                @map("template_id")
  templateName              String                 @map("template_name")
  templateVersion           Int                    @map("template_version")
  status                    String                 @default("draft")
  version                   Int                    @default(0)
  confirmedAt               DateTime?              @map("confirmed_at")
  confirmedById             String?                @map("confirmed_by_id")
  startedAt                 DateTime?              @map("started_at")
  completedAt               DateTime?              @map("completed_at")
  productTimeProfileId      String?                @map("product_time_profile_id")
  productTimeProfileVersion Int?                   @map("product_time_profile_version")
  routeSource               String                 @default("process_template") @map("route_source")
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")
  workOrder                 WorkOrder              @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  template                  ProcessTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  productTimeProfile        ProductTimeProfile?    @relation(fields: [productTimeProfileId], references: [id], onDelete: SetNull)
  confirmedBy               User?                  @relation("ProcessRouteConfirmedBy", fields: [confirmedById], references: [id], onDelete: SetNull)
  steps                     WorkOrderProcessStep[]
  activities                ProcessRouteActivity[]
  completions               ProcessCompletion[]

  @@index([status])
  @@index([templateId])
  @@index([productTimeProfileId])
  @@index([updatedAt])
  @@map("work_order_process_routes")
}

model WorkOrderProcessStep {
  id                          String                    @id @default(uuid())
  routeId                     String                    @map("route_id")
  processDefinitionId         String?                   @map("process_definition_id")
  processCode                 String                    @map("process_code")
  processName                 String                    @map("process_name")
  stageGroup                  String                    @map("stage_group")
  position                    Int
  sequenceGroup               Int                       @default(1) @map("sequence_group")
  standardTimeId              String?                   @map("standard_time_id")
  standardVersion             Int?                      @map("standard_version")
  productTimeProfileId        String?                   @map("product_time_profile_id")
  productTimeEntryId          String?                   @map("product_time_entry_id")
  productTimeProfileVersion   Int?                      @map("product_time_profile_version")
  standardSource              String                    @default("legacy") @map("standard_source")
  timeBasis                   String?                   @map("time_basis")
  unitLabel                   String?                   @map("unit_label")
  standardMillisecondsPerUnit Int?                      @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                       @default(0) @map("setup_milliseconds")
  unitsPerProduct             Int                       @default(1) @map("units_per_product")
  countsForEfficiency         Boolean                   @default(true) @map("counts_for_efficiency")
  inputQty                    Int                       @default(0) @map("input_qty")
  processedQty                Int                       @default(0) @map("processed_qty")
  goodOutputQty               Int                       @default(0) @map("good_output_qty")
  defectOutputQty             Int                       @default(0) @map("defect_output_qty")
  releasedGoodQty             Int                       @default(0) @map("released_good_qty")
  quantityVersion             Int                       @default(0) @map("quantity_version")
  status                      String                    @default("pending")
  startedAt                   DateTime?                 @map("started_at")
  completedAt                 DateTime?                 @map("completed_at")
  completedById               String?                   @map("completed_by_id")
  remark                      String?
  createdAt                   DateTime                  @default(now()) @map("created_at")
  updatedAt                   DateTime                  @updatedAt @map("updated_at")
  route                       WorkOrderProcessRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)
  processDefinition           ProcessDefinition?        @relation(fields: [processDefinitionId], references: [id], onDelete: SetNull)
  standardTime                ProcessTimeStandard?      @relation(fields: [standardTimeId], references: [id], onDelete: SetNull)
  productTimeProfile          ProductTimeProfile?       @relation(fields: [productTimeProfileId], references: [id], onDelete: SetNull)
  productTimeEntry            ProductProcessTimeEntry?  @relation(fields: [productTimeEntryId], references: [id], onDelete: SetNull)
  completedBy                 User?                     @relation("ProcessStepCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)
  activities                  ProcessRouteActivity[]
  executions                  ProcessExecution[]
  abnormalTimeEvents          AbnormalTimeEvent[]
  completions                 ProcessCompletion[]
  sourceQuantityMovements     ProcessQuantityMovement[] @relation("MovementSourceStep")
  targetQuantityMovements     ProcessQuantityMovement[] @relation("MovementTargetStep")
  processLaborPools           ProcessLaborPool[]
  originatedBranchWorkOrders  WorkOrder[]               @relation("WorkOrderBranchOriginStep")
  rejoiningBranchWorkOrders   WorkOrder[]               @relation("WorkOrderBranchRejoinStep")

  @@unique([routeId, position])
  @@index([routeId, status])
  @@index([routeId, sequenceGroup, status])
  @@index([processDefinitionId])
  @@index([standardTimeId])
  @@index([productTimeProfileId])
  @@index([productTimeEntryId])
  @@index([completedById])
  @@index([quantityVersion])
  @@map("work_order_process_steps")
}

model Employee {
  id                      String                   @id @default(uuid())
  employeeNo              String                   @unique @map("employee_no")
  name                    String
  department              String?
  position                String?
  team                    String?
  isActive                Boolean                  @default(true) @map("is_active")
  attendanceEnabled       Boolean                  @default(true) @map("attendance_enabled")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  executions              ProcessExecution[]
  attendanceRecords       AttendanceRecord[]
  abnormalTimeAllocations AbnormalTimeAllocation[]
  laborClaims             ProcessLaborClaim[]
  user                    User?

  @@index([isActive, employeeNo])
  @@index([name])
  @@index([department])
  @@index([position])
  @@index([team])
  @@index([attendanceEnabled, isActive])
  @@map("employees")
}

model ProcessExecution {
  id                          String               @id @default(uuid())
  stepId                      String               @map("step_id")
  employeeId                  String               @map("employee_id")
  startedAt                   DateTime             @map("started_at")
  endedAt                     DateTime             @map("ended_at")
  breakMilliseconds           Int                  @default(0) @map("break_milliseconds")
  goodQty                     Int                  @map("good_qty")
  scrapQty                    Int                  @default(0) @map("scrap_qty")
  reworkQty                   Int                  @default(0) @map("rework_qty")
  timeBasis                   String               @default("per_unit") @map("time_basis")
  unitLabel                   String               @map("unit_label")
  standardMillisecondsPerUnit Int                  @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                  @default(0) @map("setup_milliseconds")
  unitsPerProduct             Int                  @default(1) @map("units_per_product")
  standardLaborMilliseconds   Int                  @map("standard_labor_milliseconds")
  actualLaborMilliseconds     Int                  @map("actual_labor_milliseconds")
  attainmentBasisPoints       Int                  @map("attainment_basis_points")
  countsForEfficiency         Boolean              @default(true) @map("counts_for_efficiency")
  standardSource              String               @default("legacy") @map("standard_source")
  productTimeProfileVersion   Int?                 @map("product_time_profile_version")
  source                      String               @default("manual")
  remark                      String?
  recordedById                String?              @map("recorded_by_id")
  createdAt                   DateTime             @default(now()) @map("created_at")
  updatedAt                   DateTime             @updatedAt @map("updated_at")
  voidedAt                    DateTime?            @map("voided_at")
  step                        WorkOrderProcessStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  employee                    Employee             @relation(fields: [employeeId], references: [id], onDelete: Restrict)
  recordedBy                  User?                @relation("ProcessExecutionRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([stepId, endedAt])
  @@index([employeeId, endedAt])
  @@index([endedAt])
  @@index([voidedAt])
  @@index([recordedById])
  @@map("process_executions")
}

model ProcessCompletion {
  id                          String                    @id @default(uuid())
  workOrderId                 String                    @map("work_order_id")
  routeId                     String                    @map("route_id")
  stepId                      String                    @map("step_id")
  workDate                    DateTime                  @map("work_date") @db.Date
  completedAt                 DateTime                  @default(now()) @map("completed_at")
  processedQty                Int                       @map("processed_qty")
  goodQty                     Int                       @map("good_qty")
  defectQty                   Int                       @map("defect_qty")
  defectDisposition           ProcessDefectDisposition? @map("defect_disposition")
  routeVersion                Int                       @map("route_version")
  idempotencyKey              String                    @unique @map("idempotency_key")
  standardTimeId              String?                   @map("standard_time_id")
  standardVersion             Int?                      @map("standard_version")
  productTimeProfileId        String?                   @map("product_time_profile_id")
  productTimeEntryId          String?                   @map("product_time_entry_id")
  productTimeProfileVersion   Int?                      @map("product_time_profile_version")
  standardSource              String                    @map("standard_source")
  timeBasis                   String?                   @map("time_basis")
  unitLabel                   String?                   @map("unit_label")
  standardMillisecondsPerUnit Int?                      @map("standard_milliseconds_per_unit")
  setupMilliseconds           Int                       @default(0) @map("setup_milliseconds")
  unitsPerProduct             Int                       @default(1) @map("units_per_product")
  countsForEfficiency         Boolean                   @default(true) @map("counts_for_efficiency")
  createdById                 String?                   @map("created_by_id")
  createdAt                   DateTime                  @default(now()) @map("created_at")
  updatedAt                   DateTime                  @updatedAt @map("updated_at")
  voidedAt                    DateTime?                 @map("voided_at")
  voidedById                  String?                   @map("voided_by_id")
  voidReason                  String?                   @map("void_reason")
  workOrder                   WorkOrder                 @relation("CompletionWorkOrder", fields: [workOrderId], references: [id], onDelete: Restrict)
  route                       WorkOrderProcessRoute     @relation(fields: [routeId], references: [id], onDelete: Restrict)
  step                        WorkOrderProcessStep      @relation(fields: [stepId], references: [id], onDelete: Restrict)
  createdBy                   User?                     @relation("ProcessCompletionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  voidedBy                    User?                     @relation("ProcessCompletionVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  movements                   ProcessQuantityMovement[]
  laborPool                   ProcessLaborPool?
  branchWorkOrder             WorkOrder?                @relation("CompletionBranchWorkOrder")

  @@index([workOrderId, workDate])
  @@index([routeId, completedAt])
  @@index([stepId, completedAt])
  @@index([voidedAt])
  @@index([createdById])
  @@index([voidedById])
  @@map("process_completions")
}

model ProcessQuantityMovement {
  id                  String                @id @default(uuid())
  completionId        String                @map("completion_id")
  workOrderId         String                @map("work_order_id")
  sourceStepId        String                @map("source_step_id")
  targetStepId        String?               @map("target_step_id")
  branchWorkOrderId   String?               @map("branch_work_order_id")
  type                ProcessMovementType
  quantity            Int
  sourceSequenceGroup Int                   @map("source_sequence_group")
  targetSequenceGroup Int?                  @map("target_sequence_group")
  idempotencyKey      String                @unique @map("idempotency_key")
  createdAt           DateTime              @default(now()) @map("created_at")
  voidedAt            DateTime?             @map("voided_at")
  completion          ProcessCompletion     @relation(fields: [completionId], references: [id], onDelete: Restrict)
  workOrder           WorkOrder             @relation("MovementWorkOrder", fields: [workOrderId], references: [id], onDelete: Restrict)
  sourceStep          WorkOrderProcessStep  @relation("MovementSourceStep", fields: [sourceStepId], references: [id], onDelete: Restrict)
  targetStep          WorkOrderProcessStep? @relation("MovementTargetStep", fields: [targetStepId], references: [id], onDelete: Restrict)
  branchWorkOrder     WorkOrder?            @relation("MovementBranchWorkOrder", fields: [branchWorkOrderId], references: [id], onDelete: SetNull)

  @@index([completionId])
  @@index([workOrderId, createdAt])
