<Window x:Class="Hongmeng.WorkOrder.ImportHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工单资料库微盘导入助手"
        Width="1180" Height="760" MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7ED"
        AllowDrop="True"
        Drop="OnFilesDropped"
        DragEnter="OnFilesDragged"
        DragOver="OnFilesDragged"
        PreviewKeyDown="OnPreviewKeyDown">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="18">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="2*" />
          <ColumnDefinition Width="1.4*" />
          <ColumnDefinition Width="1.5*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
          <TextBlock Text="客户" Foreground="#9A3412" FontSize="12" />
          <TextBlock x:Name="CustomerText" Text="等待网页任务" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="16,0,0,0">
          <TextBlock Text="规格" Foreground="#9A3412" FontSize="12" />
          <TextBlock x:Name="SpecificationText" Text="-" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="16,0,0,0">
          <TextBlock Text="目标分类" Foreground="#9A3412" FontSize="12" />
          <TextBlock x:Name="CategoryText" Text="-" FontSize="17" FontWeight="SemiBold" />
        </StackPanel>
        <StackPanel Grid.Column="3" Margin="16,0,0,0">
          <TextBlock Text="任务有效期" Foreground="#9A3412" FontSize="12" />
          <TextBlock x:Name="ExpiryText" Text="-" FontSize="17" FontWeight="SemiBold" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="0,14,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.35*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="White" BorderBrush="#FB923C" BorderThickness="2" CornerRadius="12" Padding="20"
              Drop="OnFilesDropped" DragEnter="OnFilesDragged" DragOver="OnFilesDragged">
        <StackPanel HorizontalAlignment="Center">
          <TextBlock Text="把微盘文件拖到这里" FontSize="20" FontWeight="Bold" Foreground="#9A3412" HorizontalAlignment="Center" />
          <TextBlock Text="或复制文件后按 Ctrl+V" Margin="0,7,0,0" FontSize="15" Foreground="#7C2D12" HorizontalAlignment="Center" />
          <TextBlock Text="仅接收真实 PDF / JPG / JPEG / PNG / WEBP；校验通过后自动上传，不会抓取链接或 Cookie" Margin="0,9,0,0" Foreground="#78716C" TextAlignment="Center" />
          <Button Content="选择本地文件" Margin="0,14,0,0" Click="OnChooseFiles" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Margin="14,0,0,0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="16">
        <StackPanel>
          <TextBlock Text="企业微信下载目录监控" FontSize="16" FontWeight="Bold" Foreground="#9A3412" />
          <TextBlock Text="只处理本任务启动后新产生、连续 3 秒大小稳定且不再被写入的文件。" Margin="0,5,0,10" Foreground="#78716C" TextWrapping="Wrap" />
          <DockPanel LastChildFill="True">
            <Button Content="选择目录" Click="OnChooseDownloadFolder" DockPanel.Dock="Right" Margin="8,0,0,0" />
            <TextBox x:Name="DownloadFolderText" IsReadOnly="True" MinHeight="38" VerticalContentAlignment="Center" Padding="8" />
          </DockPanel>
          <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="MonitorButton" Content="开始监控" Click="OnToggleMonitor" />
            <TextBlock x:Name="MonitorStatusText" Text="未启动" VerticalAlignment="Center" Foreground="#78716C" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Margin="0,14,0,10" Padding="12,10" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
      <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
          <Button Content="上传全部" Background="{StaticResource OrangeBrush}" Foreground="White" BorderBrush="{StaticResource OrangeBrush}" Click="OnUploadAll" />
          <Button x:Name="PauseQueueButton" Content="暂停队列" Click="OnToggleQueuePause" />
          <Button Content="重试失败" Click="OnRetryFailed" />
          <Button Content="清空已完成" Click="OnClearCompleted" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="打开网页" Click="OnOpenWeb" />
          <Button Content="移除任务" Foreground="#B91C1C" BorderBrush="#FCA5A5" Click="OnRemoveTask" Margin="0" />
        </StackPanel>
      </DockPanel>
    </Border>

    <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="1">
      <DataGrid ItemsSource="{Binding QueueItems}" AutoGenerateColumns="False" IsReadOnly="False" CanUserAddRows="False"
                HeadersVisibility="Column" GridLinesVisibility="Horizontal" RowHeaderWidth="0" BorderThickness="0"
                AlternatingRowBackground="#FFFBF5" SelectionMode="Extended">
        <DataGrid.Columns>
          <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="2.2*" IsReadOnly="True" />
          <DataGridTextColumn Header="类型" Binding="{Binding MimeType}" Width="1.05*" IsReadOnly="True" />
          <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="0.75*" IsReadOnly="True" />
          <DataGridTextColumn Header="重复状态" Binding="{Binding DuplicateStatus}" Width="0.9*" IsReadOnly="True" />
          <DataGridTemplateColumn Header="进度" Width="1.1*" IsReadOnly="True">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" Height="14" Margin="4" Foreground="#F97316" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="0.9*" IsReadOnly="True" />
          <DataGridCheckBoxColumn Header="确认冲突" Binding="{Binding AllowConflictUpload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="0.75*" />
          <DataGridTextColumn Header="结果" Binding="{Binding Message}" Width="1.8*" IsReadOnly="True" />
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Border Grid.Row="4" Margin="0,10,0,0" Background="#FFEDD5" CornerRadius="8" Padding="12,8">
      <DockPanel>
        <TextBlock x:Name="StatusText" Text="请从工单资料库网页点击“从微盘导入”创建任务。" Foreground="#9A3412" TextWrapping="Wrap" />
        <TextBlock x:Name="QueueSummaryText" Text="队列 0" HorizontalAlignment="Right" Foreground="#7C2D12" FontWeight="SemiBold" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
